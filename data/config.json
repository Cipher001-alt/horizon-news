{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 3,
    "enrichment_concurrency": 2
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-sdk-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "deepseek-ai",
        "repo": "DeepSeek-V3",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ggerganov",
        "repo": "llama.cpp",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "shadcn-ui",
        "repo": "ui",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 50
    },
    "rss": [
      {
        "name": "Simon Willison — AI工具",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "The Decoder — AI新闻",
        "url": "https://the-decoder.com/feed/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "Unite.AI — AI与机器人",
        "url": "https://saizenacuity.com/rss-feeds/unite-ai/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "TechCrunch — 科技创投",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "ArsTechnica — 深度科技",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Julia Evans — 编程",
        "url": "https://jvns.ca/atom.xml",
        "enabled": true,
        "category": "skill"
      },
      {
        "name": "Dan Luu — 技术深度分析",
        "url": "https://danluu.com/atom.xml",
        "enabled": true,
        "category": "skill"
      },
      {
        "name": "EcommerceBytes — 电商新闻",
        "url": "https://www.ecommercebytes.com/feed/",
        "enabled": true,
        "category": "ecommerce"
      },
      {
        "name": "Practical Ecommerce",
        "url": "https://www.practicalecommerce.com/feed",
        "enabled": true,
        "category": "ecommerce"
      },
      {
        "name": "跨境电商雨果网",
        "url": "https://www.cifnews.com/rss.xml",
        "enabled": true,
        "category": "ecommerce"
      }
    ],
    "reddit": {
      "enabled": true,
      "fetch_comments": 3,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 10,
          "enabled": true
        },
        {
          "subreddit": "LocalLLaMA",
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 10,
          "enabled": true
        },
        {
          "subreddit": "artificial",
          "sort": "hot",
          "fetch_limit": 10,
          "min_score": 20,
          "enabled": true
        },
        {
          "subreddit": "programming",
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 30,
          "enabled": true
        },
        {
          "subreddit": "webdev",
          "sort": "hot",
          "fetch_limit": 10,
          "min_score": 10,
          "enabled": true
        },
        {
          "subreddit": "ecommerce",
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 5,
          "enabled": true
        },
        {
          "subreddit": "dropshipping",
          "sort": "hot",
          "fetch_limit": 10,
          "min_score": 5,
          "enabled": true
        },
        {
          "subreddit": "AmazonSeller",
          "sort": "hot",
          "fetch_limit": 10,
          "min_score": 5,
          "enabled": true
        }
      ],
      "users": []
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 30,
    "category_groups": {
      "ai_news": {
        "limit": 10,
        "categories": ["ai"]
      },
      "tech_skills": {
        "limit": 8,
        "categories": ["tech", "skill"]
      },
      "ecommerce": {
        "limit": 8,
        "categories": ["ecommerce"]
      }
    },
    "default_group": "other",
    "default_group_limit": 4
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
